# ─────────────────────────────────────────────────────────────────────────────
# CalTrack Backend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values below.
# Never commit .env to git — it contains secrets!
#
# Team: Get the actual values from your team lead via WhatsApp/Slack/email.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase PostgreSQL (Session Pooler — shared team DB) ────────────────────
# Get this from: supabase.com/dashboard → your project → Connect → Session Pooler
DB_NAME=postgres
DB_USER=postgres.uumyqxjolindlauyldee
DB_PASSWORD=<ask-team-lead>
DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
DB_PORT=5432

DIRECT_URL="postgresql://postgres.uumyqxjolindlauyldee:<password>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ── Django Core ───────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=<ask-team-lead>
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.localhost

# ── CORS (Frontend origins) ───────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Google OAuth (optional for local dev) ────────────────────────────────────
Client_ID=628867483502-e7snj6l150js2vpvkv70opo5h4aacgus.apps.googleusercontent.com
Client_secret=<ask-team-lead>
REDIRECT_URI=http://localhost:8000/accounts/google/login/callback/